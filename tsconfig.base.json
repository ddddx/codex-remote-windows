{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "composite": true,
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@codex-remote/protocol": [
        "packages/protocol/src/index.ts"
      ],
      "@codex-remote/domain": [
        "packages/domain/src/index.ts"
      ],
      "@codex-remote/adapters": [
        "packages/adapters/src/index.ts"
      ],
      "@codex-remote/codex-app-server-types": [
        "packages/codex-app-server-types/src/index.ts"
      ]
    }
  }
}
