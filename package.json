{
  "name": "codex-remote-tabs",
  "version": "0.1.0",
  "private": true,
  "description": "Remote tab controller for Codex on PC",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "remote": "node restart-codex-remote.js start",
    "remote:restart": "node restart-codex-remote.js",
    "remote:stop": "node restart-codex-remote.js stop",
    "appserver": "node restart-codex-remote.js appserver",
    "web": "node restart-codex-remote.js web"
  },
  "dependencies": {
    "express": "^4.21.2",
    "ws": "^8.18.3"
  }
}
