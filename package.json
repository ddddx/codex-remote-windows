{
  "name": "codex-remote-workspace",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "test:integration": "node --test --import tsx tests/integration/**/*.test.ts test/migration-script.test.ts",
    "build": "npm run build --workspaces --if-present",
    "migrate:legacy-state": "node --import tsx scripts/migrate-legacy-state.ts",
    "dev:web": "npm run dev --workspace @codex-remote/web",
    "dev:server": "npm run dev --workspace @codex-remote/server",
    "remote:start": "npm run start --workspace @codex-remote/remote",
    "remote:dev": "npm run dev --workspace @codex-remote/remote",
    "remote": "npm run remote --workspace @codex-remote/remote",
    "remote:restart": "npm run remote:restart --workspace @codex-remote/remote",
    "remote:stop": "npm run remote:stop --workspace @codex-remote/remote",
    "appserver": "npm run appserver --workspace @codex-remote/remote",
    "web": "npm run web --workspace @codex-remote/remote"
  },
  "devDependencies": {
    "@types/node": "^22.15.31",
    "tsx": "^4.20.6",
    "typescript": "^5.8.3"
  }
}
