{
  "name": "codex-remote-windows",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "test:integration": "node --test --import tsx tests/integration/**/*.test.ts test/*.test.ts test/*.test.mjs",
    "test:e2e": "playwright test",
    "build": "npm run build --workspaces --if-present",
    "sync:codex-app-server-types": "node scripts/sync-codex-app-server-types.mjs",
    "migrate:legacy-state": "node --import tsx scripts/migrate-legacy-state.ts",
    "prestart": "node scripts/free-port.mjs",
    "start": "npm run build --workspace @codex-remote/web && node --import tsx apps/server/src/index.ts",
    "stop": "node scripts/free-port.mjs",
    "dev:web": "npm run dev --workspace @codex-remote/web",
    "dev:server": "node --watch --import tsx apps/server/src/index.ts",
    "dev": "node --watch --import tsx apps/server/src/index.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^22.15.31",
    "tsx": "^4.20.6",
    "typescript": "^5.8.3"
  }
}
